<!DOCTYPE html>
<html lang="ru">
<%- include('partials/head') %>
<body>
<%- include('partials/nav') %>
<div class="container">
  <div class="channel-header">
    <% if (channel.logo_url) { %><img src="<%= channel.logo_url %>" alt="<%= channel.title %>"><% } %>
    <div>
      <h1><%= channel.title %></h1>
      <div class="channel-stats"><%= channel.views %> просмотров · <%= channel.type === 'radio' ? 'Радио' : 'Телеканал' %></div>
    </div>
  </div>

  <div class="channel-layout">
    <div>
      <div class="player-wrap" id="player-wrap">
        <% if (!activeSource) { %>
          <div style="color:#888;display:flex;align-items:center;justify-content:center;height:100%">Сейчас нет активного эфира</div>
        <% } else if (activeSource.type === 'mp4') { %>
          <video controls autoplay playsinline src="<%= activeSource.url %>"></video>
        <% } else if (activeSource.type === 'm3u8') { %>
          <video id="hls-video" controls autoplay playsinline></video>
        <% } else { %>
          <iframe src="<%= activeSource.url %>" allow="autoplay; encrypted-media; picture-in-picture" allowfullscreen></iframe>
        <% } %>
      </div>

      <% if (channel.description) { %><p style="color:var(--text-dim);margin-top:16px"><%= channel.description %></p><% } %>

      <h3 style="margin-top:28px">Расписание эфира</h3>
      <table class="schedule-table">
        <thead><tr><th>День</th><th>Время</th><th>Программа</th></tr></thead>
        <tbody>
          <% const days=['Пн','Вт','Ср','Чт','Пт','Сб','Вс']; schedule.forEach(s => { %>
          <tr><td><%= days[s.day_of_week] %></td><td><%= s.start_time %>–<%= s.end_time %></td><td><%= s.program_title || s.source_name %></td></tr>
          <% }) %>
          <% if (schedule.length === 0) { %><tr><td colspan="3" style="color:var(--text-dim)">Расписание не задано, вещание идёт по источнику по умолчанию</td></tr><% } %>
        </tbody>
      </table>
    </div>

    <div class="chat-panel">
      <div class="chat-header">Чат канала</div>
      <div class="chat-messages" id="chat-messages"></div>
      <div class="sticker-row">
        <% stickers.forEach(s => { %><img src="<%= s.image_url %>" title="<%= s.code %>" data-code="<%= s.code %>" onclick="insertSticker('<%= s.code %>')"><% }) %>
      </div>
      <div class="chat-input-row">
        <% if (currentUser) { %>
          <input type="text" id="chat-input" placeholder="Написать сообщение..." maxlength="500">
          <button class="btn btn-primary btn-sm" onclick="sendMessage()">➤</button>
        <% } else { %>
          <a href="/auth/login" class="btn btn-outline" style="width:100%;text-align:center">Войдите, чтобы писать в чат</a>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.min.js"></script>
<% if (activeSource && activeSource.type === 'm3u8') { %>
<script src="https://cdn.jsdelivr.net/npm/hls.js@1"></script>
<script>
  const video = document.getElementById('hls-video');
  const src = <%- JSON.stringify(activeSource.url) %>;
  if (Hls.isSupported()) {
    const hls = new Hls();
    hls.loadSource(src);
    hls.attachMedia(video);
  } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
    video.src = src;
  }
  video.play().catch(()=>{});
</script>
<% } %>

<script>
  const channelId = <%= channel.id %>;
  const currentUserId = <%= currentUser ? currentUser.id : 'null' %>;
  const currentUsername = <%= currentUser ? JSON.stringify(currentUser.username) : 'null' %>;
  const isModerator = <%= currentUser && (currentUser.id === channel.owner_id || currentUser.role === 'admin') ? 'true' : 'false' %>;

  const socket = io();
  socket.emit('join', { channelId });

  const box = document.getElementById('chat-messages');

  function escapeHtml(s) {
    return (s || '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }

  function renderMessage({ id, userId, username, message }) {
    const row = document.createElement('div');
    row.className = 'chat-msg';
    row.dataset.id = id;
    let delBtn = isModerator ? `<span class="del-btn" onclick="deleteMsg(${id})">удалить</span>` : '';
    row.innerHTML = `<b>${escapeHtml(username)}:</b> ${escapeHtml(message)} ${delBtn}`;
    box.appendChild(row);
    box.scrollTop = box.scrollHeight;
  }

  socket.on('chat:message', (msg) => {
    if (msg.channelId === channelId) {
      renderMessage(msg);
    }
  });

  socket.on('chat:deleted', ({ messageId }) => {
    const el = box.querySelector(`[data-id="${messageId}"]`);
    if (el) el.remove();
  });

  socket.on('chat:banned', ({ userId }) => {
    if (userId === currentUserId) alert('Вы забанены в этом чате');
  });

  socket.on('chat:error', ({ message }) => {
    console.error('Chat error:', message);
    alert(message);
  });

  function sendMessage() {
    const input = document.getElementById('chat-input');
    const message = input.value.trim();
    if (!message) return;
    
    input.disabled = true;
    socket.emit('chat:message', { channelId, message });
    input.value = '';
    input.disabled = false;
  }

  document.getElementById('chat-input')?.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  function insertSticker(code) {
    const input = document.getElementById('chat-input');
    if (input) input.value += ` ${code} `;
  }

  function deleteMsg(messageId) {
    socket.emit('chat:delete', { channelId, messageId });
  }
</script>
</body>
</html>
