<nav class="navbar">
  <a href="/" class="brand">StreamLive</a>
  <div class="nav-links">
    <a href="/channels">Каталог</a>
    <a href="/shorts" style="color:var(--primary);font-weight:bold">Shorts</a>
    <% if (currentUser) { %>
      <a href="/dashboard">Мои каналы</a>
